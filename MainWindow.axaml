<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
        x:Class="DebloaterApp.MainWindow"
        Title="Windows Debloater"
        Width="600"
        Height="500">
    <Border Padding="20">
        <StackPanel>
            <!-- Title -->
            <TextBlock FontSize="24" FontWeight="Bold" Margin="0,0,0,20">
                Windows Debloater
            </TextBlock>

            <!-- Description -->
            <TextBlock Text="Select the bloatware to remove from your system:" 
                       Margin="0,0,0,15"
                       TextWrapping="Wrap"/>

            <!-- Scrollable List of Apps -->
            <ScrollViewer Height="300" Margin="0,0,0,20" Background="#f5f5f5">
                <StackPanel x:Name="AppsPanel">
                    <!-- Copilot Checkbox -->
                    <CheckBox x:Name="CopilotCheckBox" 
                              Margin="10,10,10,10"
                              FontSize="14">
                        <TextBlock>
                            <Run FontWeight="Bold">Microsoft Copilot</Run>
                            <Run Foreground="Gray"> - AI assistant</Run>
                        </TextBlock>
                    </CheckBox>

                    <!-- More apps can be added here -->
                    <CheckBox x:Name="EdgeCheckBox" 
                              Margin="10,10,10,10"
                              FontSize="14">
                        <TextBlock>
                            <Run FontWeight="Bold">Microsoft Edge</Run>
                            <Run Foreground="Gray"> - Web browser</Run>
                        </TextBlock>
                    </CheckBox>

                    <CheckBox x:Name="OneDriveCheckBox" 
                              Margin="10,10,10,10"
                              FontSize="14">
                        <TextBlock>
                            <Run FontWeight="Bold">OneDrive</Run>
                            <Run Foreground="Gray"> - Cloud storage</Run>
                        </TextBlock>
                    </CheckBox>
                </StackPanel>
            </ScrollViewer>

            <!-- Status Message -->
            <TextBlock x:Name="StatusMessage" 
                       Margin="0,0,0,15"
                       TextWrapping="Wrap"
                       Foreground="Gray"
                       MinHeight="40"/>

            <!-- Delete Button -->
            <Button x:Name="DeleteButton" 
                    Content="Remove Selected Apps"
                    Padding="10,12"
                    FontSize="14"
                    FontWeight="Bold"/>
        </StackPanel>
    </Border>
</Window>

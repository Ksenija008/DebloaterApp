<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="750"
        x:Class="DebloaterApp.MainWindow"
        Title="Windows Debloater"
        Width="1200"
        Height="750"
        Background="#1a1a1a">

    <Border Padding="24">
        <Grid ColumnDefinitions="*,380">
            <StackPanel Grid.Column="0" Spacing="20">
            <!-- Header Section -->
            <StackPanel Spacing="8">
                <TextBlock Classes="Title" 
                           Text="Windows Debloater" />
                <TextBlock Classes="Description" 
                           Text="Select bloatware to remove from your system" />
            </StackPanel>

            <!-- Apps Section -->
            <StackPanel Spacing="12">
                <TextBlock Text="Applications" 
                           FontSize="12" 
                           FontWeight="Bold" 
                           Foreground="#A0A0A0"
                           Margin="0,0,0,4" />
                
                <Border Background="#2a2a2a" 
                        BorderBrush="#3a3a3a" 
                        BorderThickness="1" 
                        CornerRadius="8"
                        Padding="0">
                    <ScrollViewer Height="280">
                        <StackPanel Spacing="2">
                            <!-- Copilot -->
                            <Border Background="Transparent" 
                                    Padding="16,14"
                                    BorderBrush="#3a3a3a"
                                    BorderThickness="0,0,0,1">
                                <CheckBox x:Name="CopilotCheckBox" 
                                          Padding="0">
                                    <StackPanel Spacing="12" Orientation="Horizontal" Margin="8,0,0,0">
                                        <TextBlock Text="✨" FontSize="20" VerticalAlignment="Center" />
                                        <TextBlock VerticalAlignment="Center">
                                            <Run Text="Microsoft Copilot" FontWeight="SemiBold" Foreground="#FFFFFF" />
                                            <Run Text=" (AI assistant)" Foreground="#888888" FontSize="12" />
                                        </TextBlock>
                                    </StackPanel>
                                </CheckBox>
                            </Border>

                            <!-- OneDrive -->
                            <Border Background="Transparent" 
                                    Padding="16,14"
                                    BorderBrush="#3a3a3a"
                                    BorderThickness="0,0,0,1">
                                <CheckBox x:Name="OneDriveCheckBox" 
                                          Padding="0">
                                    <StackPanel Spacing="12" Orientation="Horizontal" Margin="8,0,0,0">
                                        <TextBlock Text="☁️" FontSize="20" VerticalAlignment="Center" />
                                        <TextBlock VerticalAlignment="Center">
                                            <Run Text="OneDrive" FontWeight="SemiBold" Foreground="#FFFFFF" />
                                            <Run Text=" (Cloud storage)" Foreground="#888888" FontSize="12" />
                                        </TextBlock>
                                    </StackPanel>
                                </CheckBox>
                            </Border>

                            <!-- Calculator -->
                            <Border Background="Transparent" 
                                    Padding="16,14"
                                    BorderBrush="#3a3a3a"
                                    BorderThickness="0,0,0,1">
                                <CheckBox x:Name="CalculatorCheckBox" 
                                          Padding="0">
                                    <StackPanel Spacing="12" Orientation="Horizontal" Margin="8,0,0,0">
                                        <TextBlock Text="🧮" FontSize="20" VerticalAlignment="Center" />
                                        <TextBlock VerticalAlignment="Center">
                                            <Run Text="Calculator" FontWeight="SemiBold" Foreground="#FFFFFF" />
                                            <Run Text=" (Basic app)" Foreground="#888888" FontSize="12" />
                                        </TextBlock>
                                    </StackPanel>
                                </CheckBox>
                            </Border>

                            <!-- Weather -->
                            <Border Background="Transparent" 
                                    Padding="16,14"
                                    BorderBrush="#3a3a3a"
                                    BorderThickness="0,0,0,1">
                                <CheckBox x:Name="WeatherCheckBox" 
                                          Padding="0">
                                    <StackPanel Spacing="12" Orientation="Horizontal" Margin="8,0,0,0">
                                        <TextBlock Text="🌤️" FontSize="20" VerticalAlignment="Center" />
                                        <TextBlock VerticalAlignment="Center">
                                            <Run Text="Weather" FontWeight="SemiBold" Foreground="#FFFFFF" />
                                            <Run Text=" (Bing Weather)" Foreground="#888888" FontSize="12" />
                                        </TextBlock>
                                    </StackPanel>
                                </CheckBox>
                            </Border>

                            <!-- News -->
                            <Border Background="Transparent" 
                                    Padding="16,14"
                                    BorderBrush="#3a3a3a"
                                    BorderThickness="0,0,0,1">
                                <CheckBox x:Name="NewsCheckBox" 
                                          Padding="0">
                                    <StackPanel Spacing="12" Orientation="Horizontal" Margin="8,0,0,0">
                                        <TextBlock Text="📰" FontSize="20" VerticalAlignment="Center" />
                                        <TextBlock VerticalAlignment="Center">
                                            <Run Text="News" FontWeight="SemiBold" Foreground="#FFFFFF" />
                                            <Run Text=" (Microsoft News)" Foreground="#888888" FontSize="12" />
                                        </TextBlock>
                                    </StackPanel>
                                </CheckBox>
                            </Border>

                            <!-- Media Player -->
                            <Border Background="Transparent" 
                                    Padding="16,14">
                                <CheckBox x:Name="MediaPlayerCheckBox" 
                                          Padding="0">
                                    <StackPanel Spacing="12" Orientation="Horizontal" Margin="8,0,0,0">
                                        <TextBlock Text="🎵" FontSize="20" VerticalAlignment="Center" />
                                        <TextBlock VerticalAlignment="Center">
                                            <Run Text="Media Player" FontWeight="SemiBold" Foreground="#FFFFFF" />
                                            <Run Text=" (Windows app)" Foreground="#888888" FontSize="12" />
                                        </TextBlock>
                                    </StackPanel>
                                </CheckBox>
                            </Border>

                            <!-- Xbox Gaming -->
                            <Border Background="Transparent" 
                                    Padding="16,14"
                                    BorderBrush="#3a3a3a"
                                    BorderThickness="0,0,0,1">
                                <CheckBox x:Name="XboxCheckBox" 
                                          Padding="0">
                                    <StackPanel Spacing="12" Orientation="Horizontal" Margin="8,0,0,0">
                                        <TextBlock Text="🎮" FontSize="20" VerticalAlignment="Center" />
                                        <TextBlock VerticalAlignment="Center">
                                            <Run Text="Xbox Gaming" FontWeight="SemiBold" Foreground="#FFFFFF" />
                                            <Run Text=" (Gaming service - 500MB+)" Foreground="#888888" FontSize="12" />
                                        </TextBlock>
                                    </StackPanel>
                                </CheckBox>
                            </Border>

                            <!-- Cortana -->
                            <Border Background="Transparent" 
                                    Padding="16,14"
                                    BorderBrush="#3a3a3a"
                                    BorderThickness="0,0,0,1">
                                <CheckBox x:Name="CortanaCheckBox" 
                                          Padding="0">
                                    <StackPanel Spacing="12" Orientation="Horizontal" Margin="8,0,0,0">
                                        <TextBlock Text="🔊" FontSize="20" VerticalAlignment="Center" />
                                        <TextBlock VerticalAlignment="Center">
                                            <Run Text="Cortana" FontWeight="SemiBold" Foreground="#FFFFFF" />
                                            <Run Text=" (Voice assistant - 100MB+)" Foreground="#888888" FontSize="12" />
                                        </TextBlock>
                                    </StackPanel>
                                </CheckBox>
                            </Border>

                            <!-- Solitaire & Candy Crush -->
                            <Border Background="Transparent" 
                                    Padding="16,14"
                                    BorderBrush="#3a3a3a"
                                    BorderThickness="0,0,0,1">
                                <CheckBox x:Name="GamesCheckBox" 
                                          Padding="0">
                                    <StackPanel Spacing="12" Orientation="Horizontal" Margin="8,0,0,0">
                                        <TextBlock Text="🃏" FontSize="20" VerticalAlignment="Center" />
                                        <TextBlock VerticalAlignment="Center">
                                            <Run Text="Games Bundle" FontWeight="SemiBold" Foreground="#FFFFFF" />
                                            <Run Text=" (Solitaire, Candy Crush)" Foreground="#888888" FontSize="12" />
                                        </TextBlock>
                                    </StackPanel>
                                </CheckBox>
                            </Border>

                            <!-- Movies & TV -->
                            <Border Background="Transparent" 
                                    Padding="16,14"
                                    BorderBrush="#3a3a3a"
                                    BorderThickness="0,0,0,1">
                                <CheckBox x:Name="MoviesCheckBox" 
                                          Padding="0">
                                    <StackPanel Spacing="12" Orientation="Horizontal" Margin="8,0,0,0">
                                        <TextBlock Text="🎬" FontSize="20" VerticalAlignment="Center" />
                                        <TextBlock VerticalAlignment="Center">
                                            <Run Text="Movies &amp; TV" FontWeight="SemiBold" Foreground="#FFFFFF" />
                                            <Run Text=" (Media app - 100MB+)" Foreground="#888888" FontSize="12" />
                                        </TextBlock>
                                    </StackPanel>
                                </CheckBox>
                            </Border>

                            <!-- Photos App -->
                            <Border Background="Transparent" 
                                    Padding="16,14">
                                <CheckBox x:Name="PhotosCheckBox" 
                                          Padding="0">
                                    <StackPanel Spacing="12" Orientation="Horizontal" Margin="8,0,0,0">
                                        <TextBlock Text="📸" FontSize="20" VerticalAlignment="Center" />
                                        <TextBlock VerticalAlignment="Center">
                                            <Run Text="Photos App" FontWeight="SemiBold" Foreground="#FFFFFF" />
                                            <Run Text=" (Image viewer - 100MB+)" Foreground="#888888" FontSize="12" />
                                        </TextBlock>
                                    </StackPanel>
                                </CheckBox>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </StackPanel>

            <!-- System Cleanup Section -->
            <StackPanel Spacing="12">
                <TextBlock Text="System Cleanup" 
                           FontSize="12" 
                           FontWeight="Bold" 
                           Foreground="#A0A0A0"
                           Margin="0,0,0,4" />
                
                <Border Background="#2a2a2a" 
                        BorderBrush="#3a3a3a" 
                        BorderThickness="1" 
                        CornerRadius="8"
                        Padding="0">
                    <StackPanel Spacing="2">
                        <!-- Temp Folder -->
                        <Border Background="Transparent" 
                                Padding="16,14"
                                BorderBrush="#3a3a3a"
                                BorderThickness="0,0,0,1">
                            <CheckBox x:Name="TempFolderCheckBox" 
                                      Padding="0">
                                <StackPanel Spacing="12" Orientation="Horizontal" Margin="8,0,0,0">
                                    <TextBlock Text="🗑️" FontSize="20" VerticalAlignment="Center" />
                                    <TextBlock VerticalAlignment="Center">
                                        <Run Text="Windows Temp Folder" FontWeight="SemiBold" Foreground="#FFFFFF" />
                                        <Run Text=" (Up to 2GB)" Foreground="#888888" FontSize="12" />
                                    </TextBlock>
                                </StackPanel>
                            </CheckBox>
                        </Border>

                        <!-- Browser Cache -->
                        <Border Background="Transparent" 
                                Padding="16,14"
                                BorderBrush="#3a3a3a"
                                BorderThickness="0,0,0,1">
                            <CheckBox x:Name="BrowserCacheCheckBox" 
                                      Padding="0">
                                <StackPanel Spacing="12" Orientation="Horizontal" Margin="8,0,0,0">
                                    <TextBlock Text="🌐" FontSize="20" VerticalAlignment="Center" />
                                    <TextBlock VerticalAlignment="Center">
                                        <Run Text="Browser Cache (Edge/Chrome)" FontWeight="SemiBold" Foreground="#FFFFFF" />
                                        <Run Text=" (Up to 2GB)" Foreground="#888888" FontSize="12" />
                                    </TextBlock>
                                </StackPanel>
                            </CheckBox>
                        </Border>

                        <!-- Recent Files -->
                        <Border Background="Transparent" 
                                Padding="16,14"
                                BorderBrush="#3a3a3a"
                                BorderThickness="0,0,0,1">
                            <CheckBox x:Name="RecentFilesCheckBox" 
                                      Padding="0">
                                <StackPanel Spacing="12" Orientation="Horizontal" Margin="8,0,0,0">
                                    <TextBlock Text="📂" FontSize="20" VerticalAlignment="Center" />
                                    <TextBlock VerticalAlignment="Center">
                                        <Run Text="Recent Files Cache" FontWeight="SemiBold" Foreground="#FFFFFF" />
                                        <Run Text=" (~50MB)" Foreground="#888888" FontSize="12" />
                                    </TextBlock>
                                </StackPanel>
                            </CheckBox>
                        </Border>

                        <!-- Thumbnail Cache -->
                        <Border Background="Transparent" 
                                Padding="16,14">
                            <CheckBox x:Name="ThumbnailCacheCheckBox" 
                                      Padding="0">
                                <StackPanel Spacing="12" Orientation="Horizontal" Margin="8,0,0,0">
                                    <TextBlock Text="🖼️" FontSize="20" VerticalAlignment="Center" />
                                    <TextBlock VerticalAlignment="Center">
                                        <Run Text="Thumbnail Cache" FontWeight="SemiBold" Foreground="#FFFFFF" />
                                        <Run Text=" (Up to 500MB)" Foreground="#888888" FontSize="12" />
                                    </TextBlock>
                                </StackPanel>
                            </CheckBox>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Status Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="Status" 
                           FontSize="12" 
                           FontWeight="Bold" 
                           Foreground="#A0A0A0"
                           Margin="0,0,0,4" />
                
                <Border Background="#2a2a2a" 
                        BorderBrush="#3a3a3a" 
                        BorderThickness="1" 
                        CornerRadius="8"
                        Padding="16">
                    <TextBlock x:Name="StatusMessage" 
                               Text="Ready to remove applications"
                               TextWrapping="Wrap"
                               Foreground="#E0E0E0"
                               MinHeight="50"
                               VerticalAlignment="Center" />
                </Border>
            </StackPanel>

            <!-- Action Button -->
            <Button x:Name="DeleteButton" 
                    Content="Remove Selected Apps"
                    Height="44"
                    FontSize="15"
                    FontWeight="SemiBold" />
        </StackPanel>

        <!-- Output Terminal Section (Right Side) -->
        <StackPanel Grid.Column="1" Spacing="8" Margin="16,0,0,0">
            <TextBlock Text="Command Output" 
                       FontSize="12" 
                       FontWeight="Bold" 
                       Foreground="#A0A0A0"
                       Margin="0,0,0,4" />
            
            <Border Background="#0d1117" 
                    BorderBrush="#30363d" 
                    BorderThickness="1" 
                    CornerRadius="6"
                    Padding="0">
                <TextBox x:Name="OutputTerminal"
                         Foreground="#58a6ff"
                         Background="#0d1117"
                         BorderThickness="0"
                         FontFamily="Cascadia Code, Courier New"
                         FontSize="11"
                         Padding="12"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         Text="Waiting for action..." />
            </Border>
        </StackPanel>
        </Grid>
    </Border>
</Window>
